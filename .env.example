# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID (any unique string)
APP_SECRET=               # Application secret (used for JWT signing, min 32 chars)
NODE_ENV=development      # Environment: development | production

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)
DATABASE_CA=              # CA certificate for SSL (optional, multi-line PEM)

# ── WhatsApp Cloud API (optional) ──────────────────────────────
WHATSAPP_PHONE_NUMBER_ID= # WhatsApp Business API phone number ID
WHATSAPP_ACCESS_TOKEN=    # WhatsApp Business API permanent access token

# ── Server (optional) ──────────────────────────────────────────
PORT=3000                 # Server port (default: 3000)
CORS_ORIGIN=              # Additional CORS origin (e.g. your custom domain)
