{
  "framework": null,
  "buildCommand": "npm run build:vercel",
  "outputDirectory": ".",
  "installCommand": "npm install --include=dev",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/sitemap.xml", "destination": "/api/index" },
    { "source": "/((?!.*\\..*).*)", "destination": "/index.html" }
  ]
}